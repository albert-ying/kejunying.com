/* Poetry page specific styles */
#content {
 width: 100%;
 max-width: 100%;
 padding-bottom: 4rem;
}

/* Poetry container */
.poetry-section {
 display: flex;
 flex-direction: row;
 gap: 3rem;
 margin: 3rem 0;
 padding: 2rem 0;
 border-bottom: 1px solid rgba(201, 169, 89, 0.2);
}

.poetry-section:last-of-type {
 border-bottom: none;
}

/* Chinese poetry - vertical text */
.poem-container {
 flex: 0 0 auto;
 writing-mode: vertical-rl;
 text-orientation: mixed;
 height: auto;
 max-height: 70vh;
 padding: 1.5rem;
 background: rgba(201, 169, 89, 0.03);
 border-radius: 12px;
}

body.dark-mode .poem-container {
 background: rgba(201, 169, 89, 0.06);
}

.poem-container h2 {
 font-size: 1.3rem;
 font-weight: 600;
 margin-bottom: 1rem;
 color: #c9a959;
}

.poem-container p {
 font-size: 1.1rem;
 line-height: 2;
 margin: 0;
}

.poem-container .meta {
 font-size: 0.8rem;
 color: #8b7355;
 margin-top: 1rem;
}

body.dark-mode .poem-container .meta {
 color: #a09080;
}

/* Annotation */
.annotation {
 flex: 1;
 font-size: 0.9rem;
 font-weight: 500;
 line-height: 1.75;
 color: #666;
 padding: 1.5rem;
 background: rgba(201, 169, 89, 0.05);
 border-left: 3px solid #c9a959;
 border-radius: 0 12px 12px 0;
 align-self: flex-start;
 max-width: 500px;
}

body.dark-mode .annotation {
 color: #a5a095;
 background: rgba(201, 169, 89, 0.08);
}

/* AI note */
.ai-note {
 font-family: 'Cooper Hewitt', sans-serif;
 font-size: 0.75rem;
 font-weight: 700;
 letter-spacing: 0.1em;
 text-transform: uppercase;
 color: #c9a959;
 margin-bottom: 2rem;
 padding: 0.75rem 1rem;
 background: rgba(201, 169, 89, 0.08);
 border-radius: 8px;
 display: inline-block;
}

body.dark-mode .ai-note {
 background: rgba(201, 169, 89, 0.12);
}

/* Responsive */
@media all and (max-width: 900px) {
 .poetry-section {
 flex-direction: column;
 gap: 1.5rem;
 }
 
 .poem-container {
 max-height: 50vh;
 align-self: center;
 }
 
 .annotation {
 max-width: 100%;
 }
}

&lt;/style&gt;
&lt;div class="ai-note"&gt;All notes are generated by AI&lt;/div&gt;
&lt;div class="poetry-section"&gt;
&lt;div class="poem-container heti heti--ancient"&gt;
&lt;h2&gt;后庭花破子·冬夜偶提&lt;/h2&gt;
&lt;p class="heti-verse"&gt;
寒星久靡靡，游烛漫欲熄。&lt;br&gt;
玉露凝翠翘，残花附彩衣。&lt;br&gt;
岁成疾。&lt;br&gt;
九年寻觅，待何日，方可医？
&lt;/p&gt;</description></item><item><title>Research</title><link>http://localhost:1314/research/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>http://localhost:1314/research/</guid><description>&lt;p&gt;Selection of publications. For a full list see my &lt;a href="https://scholar.google.com/citations?user=JS7AdkcAAAAJ&amp;amp;hl=en"&gt;Google Scholar profile&lt;/a&gt;&lt;/p&gt;
